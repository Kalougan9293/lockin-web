    {
      "parameters": {
        "fromEmail": "={{ $env.LOCKIN_FROM_EMAIL }}",
        "toEmail": "={{ $('4. Une relance à la fois').item.json.to }}",
        "subject": "={{ $('4. Une relance à la fois').item.json.subject }}",
        "emailFormat": "html",
        "html": "={{ $('4. Une relance à la fois').item.json.body }}",
        "options": {
          "ccEmail": "={{ $('4. Une relance à la fois').item.json.cc || '' }}"
        }
      },
      "id": "e823f9b2-3642-4f11-9fa6-07f8cfcb9b01",
      "name": "8a. Envoyer l'email (Seul)",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [2200, 200],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.LOCKIN_API_URL.replace(/\\/$/, '') + '/api/cron/relances/ack' }}",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.CRON_SECRET }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (() => {\n  const relance = $('4. Une relance à la fois').item.json;\n  const nodeEmail = $(\"8a. Envoyer l'email (Seul)\").item;\n  const failed = Boolean(nodeEmail.error);\n  const deliveryIds = Array.isArray(relance.deliveryIds) && relance.deliveryIds.length\n    ? relance.deliveryIds\n    : [relance.deliveryId];\n\n  if (failed) {\n    return {\n      deliveryIds,\n      deliveryId: relance.deliveryId,\n      status: 'failed',\n      errorMessage: String(nodeEmail.error?.message || nodeEmail.error?.description || 'Échec envoi e-mail'),\n    };\n  }\n\n  return {\n    deliveryIds,\n    deliveryId: relance.deliveryId,\n    status: 'sent',\n    providerMessageId: String($execution.id) + '-mail',\n    provider: 'smtp',\n    sentAt: new Date().toISOString(),\n  };\n})() }}",
        "options": {}
      },
      "id": "f5d0f19c-8a3b-4871-912b-3a51bc97855b",
      "name": "9a. Ack Email (Seul)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2480, 200]
    },
    {
      "parameters": {
        "from": "={{ $env.TWILIO_FROM_NUMBER }}",
        "to": "={{ $('4. Une relance à la fois').item.json.phone }}",
        "message": "={{ $('4. Une relance à la fois').item.json.smsBody }}",
        "options": {}
      },
      "id": "180b5b08-963d-4c38-89c0-be358245cd98",
      "name": "8b. Envoyer le SMS (Seul)",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [2200, 400],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.LOCKIN_API_URL.replace(/\\/$/, '') + '/api/cron/relances/ack' }}",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.CRON_SECRET }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (() => {\n  const relance = $('4. Une relance à la fois').item.json;\n  const nodeSMS = $(\"8b. Envoyer le SMS (Seul)\").item;\n  const failed = Boolean(nodeSMS.error);\n  const deliveryIds = Array.isArray(relance.deliveryIds) && relance.deliveryIds.length\n    ? relance.deliveryIds\n    : [relance.deliveryId];\n\n  if (failed) {\n    return {\n      deliveryIds,\n      deliveryId: relance.deliveryId,\n      status: 'failed',\n      errorMessage: String(nodeSMS.error?.message || nodeSMS.error?.description || 'Échec envoi SMS Twilio'),\n    };\n  }\n\n  const sid = nodeSMS.json?.sid;\n\n  return {\n    deliveryIds,\n    deliveryId: relance.deliveryId,\n    status: 'sent',\n    providerMessageId: sid ? String(sid) : String($execution.id) + '-sms',\n    provider: 'twilio',\n    sentAt: new Date().toISOString(),\n  };\n})() }}",
        "options": {}
      },
      "id": "cb1c7d8a-9f5a-4b0d-83cb-f166163ee9cc",
      "name": "9b. Ack SMS (Seul)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2480, 400]
    },
    {
      "parameters": {
        "fromEmail": "={{ $env.LOCKIN_FROM_EMAIL }}",
        "toEmail": "={{ $('4. Une relance à la fois').item.json.to }}",
