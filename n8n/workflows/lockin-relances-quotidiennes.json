        "jsonBody": "={{ (() => {\n  const relance = $('4. Une relance à la fois').item.json;\n  const deliveryIds = Array.isArray(relance.deliveryIds) && relance.deliveryIds.length\n    ? relance.deliveryIds\n    : [relance.deliveryId];\n\n  return {\n    deliveryIds,\n    deliveryId: relance.deliveryId,\n    status: 'cancelled',\n    errorMessage: 'Facture payée ou relance retirée avant envoi.',\n  };\n})() }}",
        "options": {}
      },
