      "id": "210b5b08-963d-4c38-89c0-be358245cd98",
      "name": "8d. Envoyer le SMS (Double)",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [2480, 600],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.LOCKIN_API_URL.replace(/\\/$/, '') + '/api/cron/relances/ack' }}",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.CRON_SECRET }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (() => {\n  const relance = $('4. Une relance à la fois').item.json;\n  const nodeEmail = $(\"8c. Envoyer l'email (Double)\").item;\n  const nodeSMS = $(\"8d. Envoyer le SMS (Double)\").item;\n  const emailFailed = Boolean(nodeEmail.error);\n  const smsFailed = Boolean(nodeSMS.error);\n  const deliveryIds = Array.isArray(relance.deliveryIds) && relance.deliveryIds.length\n    ? relance.deliveryIds\n    : [relance.deliveryId];\n\n  const errors = [];\n  if (emailFailed) {\n    errors.push('Email : ' + String(nodeEmail.error?.message || nodeEmail.error?.description || 'Échec envoi e-mail'));\n  }\n  if (smsFailed) {\n    errors.push('SMS : ' + String(nodeSMS.error?.message || nodeSMS.error?.description || 'Échec envoi SMS Twilio'));\n  }\n\n  if (errors.length) {\n    return {\n      deliveryIds,\n      deliveryId: relance.deliveryId,\n      status: 'failed',\n      errorMessage: errors.join(' ; '),\n    };\n  }\n\n  const smsSid = nodeSMS.json?.sid;\n\n  return {\n    deliveryIds,\n    deliveryId: relance.deliveryId,\n    status: 'sent',\n    providerMessageId: [String($execution.id) + '-mail', smsSid ? String(smsSid) : String($execution.id) + '-sms'].join(','),\n    provider: 'smtp+twilio',\n    sentAt: new Date().toISOString(),\n  };\n})() }}",
        "options": {}
      },
      "id": "ab1c7d8a-9f5a-4b0d-83cb-f166163ee9dd",
      "name": "9c. Ack Double",
      "type": "n8n-nodes-base.httpRequest",
