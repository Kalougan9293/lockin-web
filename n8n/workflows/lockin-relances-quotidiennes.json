        "emailFormat": "html",
        "html": "={{ $('4. Une relance à la fois').item.json.body }}",
        "options": {
          "ccEmail": "={{ $('4. Une relance à la fois').item.json.cc || '' }}"
        }
      },
      "id": "e919f2b8-1642-4f11-9fa6-07f8cfcb9b01",
      "name": "8c. Envoyer l'email (Double)",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [2200, 600],
      "continueOnFail": true
    },
    {
      "parameters": {
        "from": "={{ $env.TWILIO_FROM_NUMBER }}",
