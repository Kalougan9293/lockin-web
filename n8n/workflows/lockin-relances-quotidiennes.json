        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Basic ' + Buffer.from($env.TWILIO_ACCOUNT_SID + ':' + $env.TWILIO_AUTH_TOKEN).toString('base64') }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            {
              "name": "To",
              "value": "={{ $('4. Une relance à la fois').item.json.phone }}"
            },
            {
              "name": "From",
              "value": "={{ $env.TWILIO_FROM_NUMBER }}"
            },
            {
              "name": "Body",
              "value": "={{ $('4. Une relance à la fois').item.json.smsBody }}"
            }
          ]
        },
        "options": {}
      },
      "id": "a7b8c9d0-e1f2-3456-0123-56789012c6d7",
      "name": "8b. Envoyer SMS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2760, 180],
      "onError": "continueErrorOutput",
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const relance = $('4. Une relance à la fois').first().json;\nconst deliveryIds = Array.isArray(relance.deliveryIds) && relance.deliveryIds.length\n  ? relance.deliveryIds\n  : [relance.deliveryId];\n\nconst errors = [];\nconst providers = [];\nconst messageIds = [];\n\nfunction branchError(nodeName) {\n  try {\n    const items = $(nodeName).all();\n    if (!items.length) return 'non exécuté';\n    const failed = items.find((item) => item.error);\n    if (failed) {\n      const err = failed.error;\n      return String(err?.message || err?.description || err || 'erreur inconnue');\n    }\n    return null;\n  } catch (error) {\n    return String(error?.message || 'non exécuté');\n  }\n}\n\nif (relance.sendEmail) {\n  const emailError = branchError(\"7b. Envoyer l'email\");\n  if (emailError) {\n    errors.push('Email : ' + emailError);\n  } else {\n    providers.push('smtp');\n    messageIds.push(String($execution.id) + '-mail');\n  }\n}\n\nif (relance.sendSms) {\n  const smsError = branchError('8b. Envoyer SMS');\n  if (smsError) {\n    errors.push('SMS : ' + smsError);\n  } else {\n    providers.push('twilio');\n    try {\n      const sid = $('8b. Envoyer SMS').first().json?.sid;\n      messageIds.push(sid ? String(sid) : String($execution.id) + '-sms');\n    } catch {\n      messageIds.push(String($execution.id) + '-sms');\n    }\n  }\n}\n\nif (errors.length) {\n  return [{\n    json: {\n      deliveryIds,\n      deliveryId: relance.deliveryId,\n      status: 'failed',\n      errorMessage: errors.join(' ; '),\n    },\n  }];\n}\n\nreturn [{\n  json: {\n    deliveryIds,\n    deliveryId: relance.deliveryId,\n    status: 'sent',\n    provider: providers.join('+') || 'lockin',\n    providerMessageId: messageIds.join(','),\n    sentAt: new Date().toISOString(),\n  },\n}];"
      },
      "id": "b8c9d0e1-f2a3-4567-1234-67890123d7e8",
