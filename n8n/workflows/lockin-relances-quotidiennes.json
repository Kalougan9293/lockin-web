        "url": "={{ $env.LOCKIN_API_URL.replace(/\\/$/, '') + '/api/cron/check-status?ids=' + encodeURIComponent((Array.isArray($json.ligneIds) && $json.ligneIds.length ? $json.ligneIds : [$json.ligneId]).join(',')) }}",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.CRON_SECRET }}"
